# LLENS 環境変数 (このファイルは git 管理、実体の .env は gitignore)
#
# 使い方:
#   cp .env.example .env
#   # .env を編集して実値を入れる
#   docker compose up -d

# Grafana 管理者パスワード
# 初回起動時 (grafana_data volume が空の時) のみ seed される。
# 既存 volume が残っていれば中の user テーブルの設定が優先される。
GRAFANA_ADMIN_PASSWORD=replace-me

# Open WebUI 管理者の API Key
# 取得: OWUI Settings → Account → API Keys → Create new
# scripts/owui/sync-functions.py で filters/*.py を OWUI に同期する際に使う
OWUI_API_KEY=
# OWUI のエンドポイント (default は compose で expose してる localhost:8080)
# OWUI_BASE_URL=http://localhost:8080
